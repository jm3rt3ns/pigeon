# Disc Rip Automation — Configuration
# Copy to .env and adjust values, or set these as system environment variables.

# Path to makemkvcon executable
MAKEMKV_PATH=C:\Program Files (x86)\MakeMKV\makemkvcon64.exe

# Output directories
FILMS_DIR=D:\Films
SHOWS_DIR=D:\Shows

# Optical drive letter
DISC_DRIVE=D:

# MakeMKV disc index (0 = first optical drive)
DISC_INDEX=0

# Content classification thresholds (minutes)
# Titles longer than MIN_FEATURE are candidates for "main feature"
MIN_FEATURE_MINUTES=60
# Titles between MIN_EPISODE and MAX_EPISODE are candidates for "TV episode"
MIN_EPISODE_MINUTES=15
MAX_EPISODE_MINUTES=65

# How often to check for a new disc (seconds)
POLL_INTERVAL_SECONDS=10

# File used to track episode numbering across multi-disc TV seasons
BATCH_STATE_FILE=batch_state.json
